{
  "name": "@workspaces-team/pretty-bench",
  "version": "0.1.0",
  "description": "Static PNG benchmark charts for repos and CI, powered by a Rust renderer.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "pretty-bench": "./bin/pretty-bench.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "LICENSE",
    "README.md",
    "bin/",
    "docs/",
    "index.d.ts",
    "native/",
    "schemas/",
    "src/"
  ],
  "scripts": {
    "build:renderer": "node ./scripts/build-renderer.mjs --release",
    "build:renderer:debug": "node ./scripts/build-renderer.mjs",
    "prepare:native": "node ./scripts/prepare-native.mjs --release",
    "render:examples": "node ./scripts/render-examples.mjs",
    "init:examples": "node ./scripts/init-examples.mjs",
    "release:assemble": "node ./scripts/assemble-release-native.mjs",
    "release:plan": "node ./scripts/print-release-plan.mjs",
    "release:verify": "node ./scripts/verify-release.mjs",
    "test": "node --test ./tests/*.test.mjs",
    "test:renderer": "cargo test --manifest-path ./renderer/Cargo.toml",
    "check": "node --test ./tests/*.test.mjs && cargo test --manifest-path ./renderer/Cargo.toml"
  },
  "keywords": [
    "benchmark",
    "chart",
    "ci",
    "png",
    "plotters",
    "reporting",
    "static"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/workspaces-team/pretty-bench.git"
  },
  "homepage": "https://github.com/workspaces-team/pretty-bench#readme",
  "bugs": {
    "url": "https://github.com/workspaces-team/pretty-bench/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
