{
  "name": "pretty-bench",
  "version": "0.1.0",
  "description": "Render benchmark charts to PNG. No browser, no JS deps.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "pretty-bench": "./bin/pretty-bench.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "types": "./index.d.ts",
  "files": [
    "LICENSE",
    "README.md",
    "CONTRIBUTING.md",
    "assets/",
    "bin/",
    "index.d.ts",
    "native/",
    "schemas/",
    "src/"
  ],
  "scripts": {
    "test": "node --test ./tests/*.test.mjs && cargo test --manifest-path ./renderer/Cargo.toml",
    "build": "node ./scripts/build-renderer.mjs --release",
    "examples": "node ./scripts/render-examples.mjs"
  },
  "keywords": [
    "benchmark",
    "chart",
    "png",
    "cli",
    "rust",
    "napi",
    "ci"
  ],
  "repository": "github:workspaces-team/pretty-bench",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
