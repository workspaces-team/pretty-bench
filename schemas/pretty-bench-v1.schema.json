{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workspaces-team.github.io/pretty-bench/schema/pretty-bench-v1.schema.json",
  "title": "pretty-bench v1 chart spec",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "type", "title", "labels", "series"],
  "properties": {
    "version": {
      "const": 1
    },
    "type": {
      "enum": ["bar", "grouped-bar", "line"]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "subtitle": {
      "type": "string"
    },
    "unit": {
      "type": "string"
    },
    "width": {
      "type": "integer",
      "minimum": 320,
      "maximum": 4096
    },
    "height": {
      "type": "integer",
      "minimum": 240,
      "maximum": 4096
    },
    "labels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "series": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "values"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "color": {
            "type": "string",
            "pattern": "^#([A-Fa-f0-9]{6})$"
          },
          "values": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "number"
            }
          }
        }
      }
    },
    "yAxis": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        }
      }
    }
  }
}
